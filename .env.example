# Kopiere diese Datei als ".env" und fülle die Werte aus.
# Alle Pfade können Windows-Umgebungsvariablen enthalten (z.B. %USERPROFILE%).

# Übergeordneter Ordner für das Projekt
FOLDER_PATH=C:\Dein\Pfad\Portfolio

# Ordner, in dem die heruntergeladenen iShares-CSV-Dateien gespeichert werden
DOWNLOAD_PATH=%FOLDER_PATH%\csv

# Ordner, in dem die erzeugten Charts (PDF) gespeichert werden
SAVE_PATH=%FOLDER_PATH%\charts

# Pfad zur Depot-Excel-Datei (Eingabe)
INPUT_FILE=%FOLDER_PATH%\depot.xlsx

# Pfad zur Ergebnis-Excel-Datei (Ausgabe)
OUTPUT_FILE=%FOLDER_PATH%\output.xlsx

# Kommagetrennte Liste der iShares-CSV-Download-URLs
CSV_URL=https://www.ishares.com/de/privatanleger/de/produkte/251882/ISHARES_CORE_MSCI_WORLD_ETF/1478372549651.ajax?fileType=csv&fileName=iShares-Core-MSCI-World-UCITS-ETF-USD-Acc_fund&dataType=fund

# Dateinamen für die heruntergeladenen CSVs (gleiche Reihenfolge wie CSV_URL)
ETF_CSV_FILE=IWDA.csv

# Suffixe für Aktien/ETFs auf Yahoo Finance (kommagetrennt, z.B. .DE für Xetra, leer für US)
STOCK_TICKER_SUFFIXES=.DE,

# Suffixe für Kryptowährungen auf Yahoo Finance (kommagetrennt)
CRYPTO_TICKER_SUFFIXES=-EUR,-USD

